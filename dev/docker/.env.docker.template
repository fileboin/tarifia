# Docker Development Environment Configuration
# This file is automatically copied to .env.docker when running docker-dev
#
# All variables have sensible defaults. Only uncomment and modify
# values if you need to customize the development environment.

# Instance number for port isolation (0 = default ports, no offset)
# Set via: dev docker set-instance <number>
# TARIFIA_DOCKER_INSTANCE=

# Database credentials (defaults work out of the box)
# TARIFIA_POSTGRES_USER=tarifia
# TARIFIA_POSTGRES_PWD=tarifia
# TARIFIA_POSTGRES_DATABASE=tarifia
# TARIFIA_POSTGRES_READ_USER=tarifia_read
# TARIFIA_POSTGRES_READ_PWD=tarifia

# MinIO credentials (defaults work out of the box)
# TARIFIA_MINIO_USER=tarifia
# TARIFIA_MINIO_PWD=tarifiatarifia
# TARIFIA_AWS_ACCESS_KEY_ID=tarifia-development
# TARIFIA_AWS_SECRET_ACCESS_KEY=tarifia123456789
# TARIFIA_S3_FILES_BUCKET_NAME=tarifia-s3
# TARIFIA_S3_FILES_PUBLIC_BUCKET_NAME=tarifia-s3-public

# Optional: GitHub integration (for full OAuth features)
# TARIFIA_GITHUB_CLIENT_ID=
# TARIFIA_GITHUB_CLIENT_SECRET=
# TARIFIA_GITHUB_APP_NAMESPACE=

# Optional: Stripe integration (for payment features)
# TARIFIA_STRIPE_SECRET_KEY=
# TARIFIA_STRIPE_PUBLISHABLE_KEY=
# TARIFIA_STRIPE_WEBHOOK_SECRET=
# TARIFIA_STRIPE_CONNECT_WEBHOOK_SECRET=

# Optional: Prometheus remote write URL
# TARIFIA_PROMETHEUS_REMOTE_WRITE_URL=
