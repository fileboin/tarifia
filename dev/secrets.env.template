# Tarifia Development Secrets
# Copy to ~/.config/tarifia/secrets.env and fill in values
#
# This file is used to share secrets across multiple Git worktrees.
# Run ./dev/setup-environment to automatically merge these into server/.env

# GitHub OAuth - create app at https://github.com/settings/apps
# Or run: ./dev/setup-environment --setup-github-app
TARIFIA_GITHUB_CLIENT_ID=
TARIFIA_GITHUB_CLIENT_SECRET=
TARIFIA_GITHUB_APP_WEBHOOK_SECRET=
TARIFIA_GITHUB_APP_IDENTIFIER=
TARIFIA_GITHUB_APP_PRIVATE_KEY=
TARIFIA_GITHUB_APP_NAMESPACE=

# GitHub Repository Benefits App (usually same as above)
TARIFIA_GITHUB_REPOSITORY_BENEFITS_APP_NAMESPACE=
TARIFIA_GITHUB_REPOSITORY_BENEFITS_APP_IDENTIFIER=
TARIFIA_GITHUB_REPOSITORY_BENEFITS_APP_PRIVATE_KEY=
TARIFIA_GITHUB_REPOSITORY_BENEFITS_CLIENT_ID=
TARIFIA_GITHUB_REPOSITORY_BENEFITS_CLIENT_SECRET=

# Stripe - from https://dashboard.stripe.com/test/apikeys
TARIFIA_STRIPE_SECRET_KEY=
TARIFIA_STRIPE_PUBLISHABLE_KEY=
TARIFIA_STRIPE_WEBHOOK_SECRET=
TARIFIA_STRIPE_CONNECT_WEBHOOK_SECRET=
