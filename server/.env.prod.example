###############################################################################
# Tarifia / Polar – Production .env
#
# Copy to ../.env.prod (repo root, next to docker-compose.prod.yml):
#   cp server/.env.prod.example .env.prod
#
# Lines marked [REQUIRED] MUST be set before the stack will start.
# Lines marked [OPTIONAL] have safe defaults or disable a feature when absent.
# Lines marked [NO-STRIPE] are specifically for running without Stripe.
###############################################################################

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------

POLAR_ENV=production
POLAR_LOG_LEVEL=INFO

# [REQUIRED] 32+ random chars — used to sign JWTs and sessions.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
POLAR_SECRET=CHANGE_ME_RANDOM_32_CHARS_OR_MORE

# [REQUIRED] Path to JWKS file baked into the Docker image (generated at build).
# In production the image's generate_dev_jwks task creates it during build.
# To generate manually: uv run task generate_dev_jwks  (creates .jwks.json)
POLAR_JWKS=/app/server/.jwks.json
POLAR_CURRENT_JWK_KID=polar_prod

# ---------------------------------------------------------------------------
# Public URLs  [REQUIRED]
# ---------------------------------------------------------------------------

# The public URL of the API (what browsers and webhooks send requests to).
POLAR_BASE_URL=https://api.example.com

# The public URL of the frontend.
POLAR_FRONTEND_BASE_URL=https://app.example.com

# Caddy domains (used by Caddyfile.prod)
DOMAIN_API=api.example.com
DOMAIN_WEB=app.example.com
CADDY_ACME_EMAIL=admin@example.com

# Checkout redirect URL (keep the {client_secret} placeholder)
POLAR_CHECKOUT_BASE_URL=https://api.example.com/v1/checkout-links/{client_secret}/redirect

# CORS — JSON list of allowed frontend origins
POLAR_CORS_ORIGINS=["https://app.example.com"]
POLAR_ALLOWED_HOSTS=["app.example.com"]

# Cookie domain — must match POLAR_FRONTEND_BASE_URL hostname
POLAR_USER_SESSION_COOKIE_DOMAIN=example.com
POLAR_AUTHENTICATION_SESSION_COOKIE_DOMAIN=example.com
POLAR_OAUTH2_SESSION_STATE_COOKIE_DOMAIN=example.com

# ---------------------------------------------------------------------------
# PostgreSQL  [REQUIRED]
# (host/port are overridden by docker-compose.prod.yml to "db:5432")
# ---------------------------------------------------------------------------

POLAR_POSTGRES_USER=polar
POLAR_POSTGRES_PWD=CHANGE_ME_STRONG_DB_PASSWORD
POLAR_POSTGRES_DATABASE=polar
# Read replica — same as primary for single-node VPS
POLAR_POSTGRES_READ_USER=polar_read
POLAR_POSTGRES_READ_PWD=CHANGE_ME_READONLY_PASSWORD

# ---------------------------------------------------------------------------
# Redis  [REQUIRED]
# (host/port overridden by docker-compose to "redis:6379")
# ---------------------------------------------------------------------------

POLAR_REDIS_DB=0

# ---------------------------------------------------------------------------
# S3 / MinIO  [REQUIRED]
# ---------------------------------------------------------------------------

# MinIO root credentials (must be ≥8 chars)
POLAR_MINIO_USER=polar-admin
POLAR_MINIO_PWD=CHANGE_ME_MINIO_PASSWORD_MIN8

# S3 access key pair (separate from MinIO root — set in minio-setup)
POLAR_AWS_ACCESS_KEY_ID=polar-s3-key
POLAR_AWS_SECRET_ACCESS_KEY=CHANGE_ME_S3_SECRET_KEY

POLAR_AWS_REGION=us-east-1

# Bucket names
POLAR_S3_FILES_BUCKET_NAME=tarifia-files
POLAR_S3_FILES_PUBLIC_BUCKET_NAME=tarifia-files-public
POLAR_S3_CUSTOMER_INVOICES_BUCKET_NAME=tarifia-files
POLAR_S3_CUSTOMER_RECEIPTS_BUCKET_NAME=tarifia-files
POLAR_S3_PAYOUT_INVOICES_BUCKET_NAME=tarifia-files

# File download security
# Generate: python3 -c "import secrets; print(secrets.token_hex(24))"
POLAR_S3_FILES_DOWNLOAD_SECRET=CHANGE_ME_DOWNLOAD_SECRET
POLAR_S3_FILES_DOWNLOAD_SALT=CHANGE_ME_DOWNLOAD_SALT

# ---------------------------------------------------------------------------
# Email  [REQUIRED for sending transactional email]
# ---------------------------------------------------------------------------

# Use "resend" for real email, "logger" to print to stdout (dev only)
POLAR_EMAIL_SENDER=resend

# [REQUIRED when POLAR_EMAIL_SENDER=resend]
POLAR_RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX

POLAR_EMAIL_FROM_NAME=Tarifia
POLAR_EMAIL_FROM_DOMAIN=notifications.example.com
POLAR_EMAIL_FROM_LOCAL=mail
POLAR_EMAIL_DEFAULT_REPLY_TO_NAME=Tarifia Support
POLAR_EMAIL_DEFAULT_REPLY_TO_EMAIL_ADDRESS=support@example.com

# ---------------------------------------------------------------------------
# [NO-STRIPE] BTCPay Server  [REQUIRED for no-KYC payments]
# ---------------------------------------------------------------------------

# Route all new checkouts through BTCPay instead of Stripe
POLAR_DEFAULT_PAYMENT_PROCESSOR=btcpay

# Your self-hosted BTCPay Server (no trailing slash)
POLAR_BTCPAY_URL=https://btcpay.example.com

# Store ID: BTCPay → Store Settings → General → Store ID
POLAR_BTCPAY_STORE_ID=CHANGE_ME_BTCPAY_STORE_ID

# API Key: BTCPay → Account → API Keys → Create → select "Create invoices" + "View invoices"
POLAR_BTCPAY_API_KEY=CHANGE_ME_BTCPAY_API_KEY

# Webhook secret: BTCPay → Store → Webhooks → Add webhook → Secret
# Webhook URL to configure in BTCPay:
#   https://api.example.com/v1/integrations/btcpay/webhook
# Events to subscribe: InvoiceSettled, InvoiceExpired, InvoiceInvalid
POLAR_BTCPAY_WEBHOOK_SECRET=CHANGE_ME_BTCPAY_WEBHOOK_SECRET

# ---------------------------------------------------------------------------
# Stripe  [OPTIONAL — leave empty to disable]
# Required only if you want to offer Stripe alongside BTCPay.
# If DEFAULT_PAYMENT_PROCESSOR=btcpay and these are empty, Stripe is inactive.
# ---------------------------------------------------------------------------

POLAR_STRIPE_SECRET_KEY=
POLAR_STRIPE_PUBLISHABLE_KEY=
POLAR_STRIPE_WEBHOOK_SECRET=
POLAR_STRIPE_CONNECT_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Frontend (Next.js) — build-time env vars
# These are embedded into the browser bundle at `docker compose build web`.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_FRONTEND_BASE_URL=https://app.example.com
NEXT_PUBLIC_BACKOFFICE_URL=https://api.example.com/backoffice

# Leave __UNSET__ when not using Stripe frontend SDK
NEXT_PUBLIC_STRIPE_KEY=__UNSET__

# Leave __UNSET__ when not using GitHub App
NEXT_PUBLIC_GITHUB_APP_NAMESPACE=__UNSET__

# S3/MinIO public image URL (used for product images displayed in browser)
# Set HOSTNAME to your domain or VPS IP where MinIO is accessible.
# If MinIO is behind Caddy with a domain, use https + domain.
S3_PUBLIC_IMAGES_BUCKET_PROTOCOL=https
S3_PUBLIC_IMAGES_BUCKET_HOSTNAME=s3.example.com
S3_PUBLIC_IMAGES_BUCKET_PORT=
S3_PUBLIC_IMAGES_BUCKET_PATHNAME=**
S3_UPLOAD_ORIGINS=https://s3.example.com

# ---------------------------------------------------------------------------
# GitHub OAuth  [OPTIONAL — required for GitHub login]
# ---------------------------------------------------------------------------

POLAR_GITHUB_CLIENT_ID=
POLAR_GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Google OAuth  [OPTIONAL — required for Google login]
# ---------------------------------------------------------------------------

POLAR_GOOGLE_CLIENT_ID=
POLAR_GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Discord  [OPTIONAL — required for Discord benefit/integration]
# ---------------------------------------------------------------------------

POLAR_DISCORD_CLIENT_ID=
POLAR_DISCORD_CLIENT_SECRET=
POLAR_DISCORD_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Invoices  [REQUIRED if issuing invoices/payouts]
# ---------------------------------------------------------------------------

POLAR_INVOICES_NAME=Your Company Name
# JSON — match Pydantic Address schema
POLAR_INVOICES_ADDRESS={"line1":"123 Main St","postal_code":"10001","city":"New York","state":"US-NY","country":"US"}
POLAR_INVOICES_ADDITIONAL_INFO="[support@example.com](mailto:support@example.com)"

# ---------------------------------------------------------------------------
# Observability  [OPTIONAL]
# ---------------------------------------------------------------------------

POLAR_SENTRY_DSN=
POLAR_LOGFIRE_TOKEN=
POLAR_POSTHOG_PROJECT_API_KEY=

# ---------------------------------------------------------------------------
# Docker Compose tuning  [OPTIONAL]
# ---------------------------------------------------------------------------

RELEASE_VERSION=1.0.0
API_WORKERS=2
WORKER_PROCESSES=2
WORKER_THREADS=2
